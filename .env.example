# PostgreSQL — use Neon (recommended for Vercel) or local Docker Postgres
# For Neon: DATABASE_URL = pooled connection, DIRECT_URL = direct connection
DATABASE_URL="postgresql://moodcast:moodcast@localhost:5433/moodcast?schema=public"
DIRECT_URL="postgresql://moodcast:moodcast@localhost:5433/moodcast?schema=public"

# Required in production (Vercel)
JWT_SECRET="change-me-in-production-use-long-random-string"

# Optional — Vercel sets VERCEL_URL automatically
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional — set on Vercel to seed demo data after first deploy
# ADMIN_SECRET="your-random-admin-secret"
