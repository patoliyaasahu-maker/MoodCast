# Neon PostgreSQL
# Local dev — use DIRECT connection for both:
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=5&pool_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Vercel production — set in dashboard:
# DATABASE_URL = pooled URL + ?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL   = direct URL + ?sslmode=require

JWT_SECRET="change-me-in-production-use-long-random-string"
ADMIN_SECRET="optional-for-seed-api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
